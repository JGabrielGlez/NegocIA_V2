# Firebase Configuration
# Obtener desde: https://console.firebase.google.com/ → Configuración del proyecto → General
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# RevenueCat Configuration (Semana 7-8 — Sistema de Pagos)
# Obtener desde: https://app.revenuecat.com/ → Settings → API Keys → Google Play
# Nota: Esta API Key es PÚBLICA en la app (por diseño de RevenueCat), no es sensible exponerla
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# RevenueCat Webhook Secret (SOLO en servidor/Cloud Functions)
# Obtener desde: https://app.revenuecat.com/ → Settings → Apps → {Tu App Android} → Event Webhooks
# Importante: NUNCA exponer en el cliente. Solo en variables de entorno del servidor Firebase.
# Se usa para verificar que los webhooks de RevenueCat son auténticos (validación HMAC SHA256)
REVENUECAT_WEBHOOK_SECRET=
