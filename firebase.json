{
    "firestore": {
        "rules": "firestore.rules"
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "disallowLegacyRuntimeConfig": true,
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ],
            "predeploy": [
                "npm --prefix \"$RESOURCE_DIR\" run lint",
                "npm --prefix \"$RESOURCE_DIR\" run build"
            ]
        }
    ],
    "emulators": {
        "auth": {
            "port": 1212,
            "host": "0.0.0.0"
        },
        "functions": {
            "port": 1213,
            "host": "0.0.0.0"
        },
        "firestore": {
            "port": 1214,
            "host": "0.0.0.0"
        },
        "hosting": {
            "port": 1215,
            "host": "0.0.0.0"
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": true
    }
}
