{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 1212
    },
    "functions": {
      "port": 1213
    },
    "firestore": {
      "port": 1214
    },
    "hosting": {
      "port": 1215
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
