# Gemini API Key — Obtén tu clave en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Firebase Project ID (GCP_PROJECT_ID es la variable correcta para emuladores)
GCP_PROJECT_ID=tu_project_id_aqui

# RevenueCat Webhook Secret — Obtén este valor desde RevenueCat Console > Integrations > Webhooks
# Usado para validar la firma HMAC de los webhooks de RevenueCat
REVENUECAT_WEBHOOK_SECRET=tu_webhook_secret_aqui
